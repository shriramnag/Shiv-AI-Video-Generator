    "<script>\n",
    "const VOICES=[{id:\\\"hm\\\",name:\\\"Shiv (Hindi)\\\",desc:\\\"Hindi Male\\\",lang:\\\"hi-IN\\\"},{id:\\\"hf\\\",name:\\\"Devi (Hindi)\\\",desc:\\\"Hindi Female\\\",lang:\\\"hi-IN\\\"},{id:\\\"em\\\",name:\\\"Arjun (Eng)\\\",desc:\\\"English Male\\\",lang:\\\"en-US\\\"},{id:\\\"ef\\\",name:\\\"Priya (Eng)\\\",desc:\\\"English Female\\\",lang:\\\"en-US\\\"}];\n",
    "let selV=VOICES[0],genImgs=[],genScenes=[],isGen=false;\n",
    "function initVoices(){const g=document.getElementById(\\\"vg\\\");g.innerHTML=\\\"\\\";VOICES.forEach(v=>{const b=document.createElement(\\\"button\\\");b.className=\\\"vb\\\"+(v.id===selV.id?\\\" sel\\\":\\\"\\\");b.innerHTML=\\\"<div class='vn'>\\\"+v.name+\\\"</div><div class='vd'>\\\"+v.desc+\\\"</div>\\\";b.onclick=()=>{selV=v;initVoices()};g.appendChild(b)});}\n",
    "function updateRatio(){const c=document.getElementById(\\\"cv\\\"),ar=document.getElementById(\\\"ar\\\").value;if(ar===\\\"9:16\\\"){c.width=450;c.height=800;}else if(ar===\\\"1:1\\\"){c.width=600;c.height=600;}else{c.width=800;c.height=450;}blackCanvas();}\n",
    "function blackCanvas(){const c=document.getElementById(\\\"cv\\\"),ctx=c.getContext(\\\"2d\\\");ctx.fillStyle=\\\"#05080e\\\";ctx.fillRect(0,0,c.width,c.height);}\n",
    "function loadEg(){document.getElementById(\\\"sc\\\").value=\\\"Jay Shri Ram. Bharat ek mahaan desh hai. Yahan ki nadiyan aur pahad bahut sundar hain. Shiv ki kripa se yeh desh hamesha unnati kare. Jay Hind.\\\";upWC();}\n",
    "function upWC(){const t=document.getElementById(\\\"sc\\\").value.trim(),wc=t?t.split(/\\\\s+/).length:0;document.getElementById(\\\"wc\\\").textContent=wc+\\\" words\\\";const sc=splitScenes(t);document.getElementById(\\\"sc2\\\").textContent=t?(sc.length+\\\" scenes\\\"):\\\"\\\";}\n",
    "document.getElementById(\\\"sc\\\").oninput=upWC;\n",
    "function setS(msg,state){document.getElementById(\\\"stxt\\\").textContent=msg;document.getElementById(\\\"dot\\\").className=\\\"dot \\\"+(state||\\\"go\\\");}\n",
    "function setStep(n,st){document.getElementById(\\\"st\\\"+n).className=\\\"step \\\"+st;}\n",
    "function setProgress(pct,label){const pw=document.getElementById(\\\"pw\\\");pw.classList.add(\\\"show\\\");document.getElementById(\\\"pf\\\").style.width=pct+\\\"%\\\";document.getElementById(\\\"ptxt\\\").textContent=label||Math.round(pct)+\\\"%\\\";}\n",
    "function hideProgress(){document.getElementById(\\\"pw\\\").classList.remove(\\\"show\\\");}\n",
    "function splitScenes(text){if(!text.trim())return[];const raw=text.replace(/([\\u0964.!?])\\\\s*/g,\\\"$1|||\\\").split(\\\"|||\\\").map(s=>s.trim()).filter(s=>s.length>2);if(!raw.length)return[text.trim()];const out=[];let buf=\\\"\\\";for(const s of raw){buf+=(buf?\\\" \\\":\\\"\\\")+s;if(buf.split(/\\\\s+/).length>=4){out.push(buf);buf=\\\"\\\";}}if(buf)out.push(buf);return out;}\n",
    "function makePrompt(scene,style){return scene.replace(/[\\u0964!?.]/g,\\\"\\\").substring(0,100).trim()+\\\", \\\"+style+\\\", high quality, detailed, vibrant\\\";}\n",
    "function loadImg(url){return new Promise((res,rej)=>{const img=new Image();img.crossOrigin=\\\"anonymous\\\";const tid=setTimeout(()=>rej(new Error(\\\"timeout\\\")),40000);img.onload=()=>{clearTimeout(tid);res(img);};img.onerror=()=>{clearTimeout(tid);rej(new Error(\\\"error\\\"));};img.src=url;});}\n",
    "async function fetchSceneImg(prompt,w,h){const seed=Math.floor(Math.random()*99999);const urls=[\\\"https://image.pollinations.ai/prompt/\\\"+encodeURIComponent(prompt)+\\\"?width=\\\"+w+\\\"&height=\\\"+h+\\\"&nologo=true&seed=\\\"+seed+\\\"&model=flux\\\",\\\"https://image.pollinations.ai/prompt/\\\"+encodeURIComponent(prompt)+\\\"?width=\\\"+w+\\\"&height=\\\"+h+\\\"&nologo=true&seed=\\\"+(seed+1)+\\\"&model=turbo\\\",\\\"https://image.pollinations.ai/prompt/\\\"+encodeURIComponent(prompt)+\\\"?width=512&height=512&nologo=true&seed=\\\"+(seed+2)];for(const url of urls){try{return await loadImg(url);}catch(e){await sleep(800);}}return null;}\n",
    "function drawFrame(ctx,img,W,H,f,total,text,kb){const p=total>1?f/(total-1):0;ctx.clearRect(0,0,W,H);if(img){if(kb){const sc=1+p*0.04;ctx.save();ctx.translate(-(W*(sc-1))/2,-(H*(sc-1))/2);ctx.scale(sc,sc);ctx.drawImage(img,0,0,W,H);ctx.restore();}else{ctx.drawImage(img,0,0,W,H);}}else{const gp=ctx.createLinearGradient(0,0,W,H);gp.addColorStop(0,\\\"#0a1628\\\");gp.addColorStop(1,\\\"#050810\\\");ctx.fillStyle=gp;ctx.fillRect(0,0,W,H);}const grad=ctx.createLinearGradient(0,H*0.5,0,H);grad.addColorStop(0,\\\"rgba(0,0,0,0)\\\");grad.addColorStop(1,\\\"rgba(0,0,0,0.82)\\\");ctx.fillStyle=grad;ctx.fillRect(0,0,W,H);const fs=Math.max(14,Math.round(W*0.027));ctx.font=\\\"500 \\\"+fs+\\\"px DM Sans,sans-serif\\\";ctx.fillStyle=\\\"rgba(255,255,255,0.95)\\\";ctx.textAlign=\\\"center\\\";ctx.shadowColor=\\\"rgba(0,0,0,0.95)\\\";ctx.shadowBlur=12;const mw=W*0.88,words=text.split(\\\" \\\");let line=\\\"\\\",lines=[];for(const w of words){const test=line+(line?\\\" \\\":\\\"\\\")+w;if(ctx.measureText(test).width>mw&&line){lines.push(line);line=w;}else{line=test;}}if(line)lines.push(line);const lh=fs*1.45,startY=H-lh*lines.length+fs*0.4-12;lines.slice(0,3).forEach((l,i)=>ctx.fillText(l,W/2,startY+i*lh));ctx.shadowBlur=0;ctx.fillStyle=\\\"rgba(255,255,255,0.08)\\\";ctx.fillRect(0,H-3,W,3);ctx.fillStyle=\\\"#3b82f6\\\";ctx.fillRect(0,H-3,W*p,3);ctx.font=\\\"400 \\\"+Math.max(9,Math.round(W*0.018))+\\\"px DM Sans\\\";ctx.fillStyle=\\\"rgba(255,255,255,0.25)\\\";ctx.textAlign=\\\"right\\\";ctx.fillText(\\\"\\u1f531 SHIV AI\\\",W-10,16);ctx.textAlign=\\\"center\\\";}\n",
    "async function startGen(){if(isGen)return;const script=document.getElementById(\\\"sc\\\").value.trim();if(!script){setS(\\\"Script likhein pehle!\\\",\\\"er\\\");return;}const scenes=splitScenes(script);if(!scenes.length){setS(\\\"Valid script likhein\\\",\\\"er\\\");return;}isGen=true;genImgs=[];genScenes=scenes;const btn=document.getElementById(\\\"gbtn\\\");btn.disabled=true;btn.classList.add(\\\"loading\\\");btn.childNodes[1].textContent=\\\" Generating...\\\";document.getElementById(\\\"dlv\\\").disabled=true;document.getElementById(\\\"dla\\\").disabled=true;document.getElementById(\\\"cvo\\\").classList.add(\\\"h\\\");const style=document.getElementById(\\\"sty\\\").value,fps=parseInt(document.getElementById(\\\"fps\\\").value),dur=parseInt(document.getElementById(\\\"dur\\\").value),kb=document.getElementById(\\\"kb\\\").checked,cv=document.getElementById(\\\"cv\\\"),ctx=cv.getContext(\\\"2d\\\"),W=cv.width,H=cv.height,FPF=fps*dur;setStep(1,\\\"go\\\");setStep(2,\\\"\\\");setStep(3,\\\"\\\");setS(\\\"Script \\u2192 \\\"+scenes.length+\\\" scenes\\\");setProgress(5,\\\"Parsing...\\\");await sleep(400);setStep(1,\\\"ok\\\");setStep(2,\\\"go\\\");document.getElementById(\\\"prevP\\\").style.display=\\\"block\\\";document.getElementById(\\\"strip\\\").innerHTML=\\\"\\\";document.getElementById(\\\"ic\\\").textContent=scenes.length+\\\" scenes\\\";for(let i=0;i<scenes.length;i++){setS(\\\"Image \\\"+(i+1)+\\\"/\\\"+scenes.length+\\\" generate ho rahi hai...\\\");setProgress(10+Math.round((i/scenes.length)*50),\\\"Image \\\"+(i+1)+\\\"/\\\"+scenes.length);const strip=document.getElementById(\\\"strip\\\"),wrap=document.createElement(\\\"div\\\");wrap.className=\\\"thumb loading\\\";wrap.innerHTML=\\\"<span style='font-size:10px;color:var(--mu)'>&#9203;</span>\\\";strip.appendChild(wrap);const img=await fetchSceneImg(makePrompt(scenes[i],style),W,H);genImgs.push(img);wrap.classList.remove(\\\"loading\\\");wrap.innerHTML=\\\"\\\";if(img){const tc=document.createElement(\\\"canvas\\\");tc.width=90;tc.height=56;tc.style.cssText=\\\"width:90px;height:56px;display:block\\\";tc.getContext(\\\"2d\\\").drawImage(img,0,0,90,56);wrap.appendChild(tc);drawFrame(ctx,img,W,H,0,FPF,scenes[i],kb);}else{wrap.innerHTML=\\\"<span style='color:var(--err);font-size:16px'>&#10007;</span>\\\";}}setStep(2,\\\"ok\\\");setStep(3,\\\"go\\\");setS(\\\"Video render ho raha hai...\\\");let totalF=scenes.length*FPF,done=0;for(let i=0;i<scenes.length;i++){for(let f=0;f<FPF;f++){drawFrame(ctx,genImgs[i]||null,W,H,f,FPF,scenes[i],kb);done++;if(f%Math.max(1,Math.floor(FPF/6))===0){setProgress(60+Math.round((done/totalF)*38),\\\"Rendering \\\"+Math.round(done/totalF*100)+\\\"%\\\");await sleep(1);}}}setStep(3,\\\"ok\\\");setProgress(100,\\\"Complete!\\\");setS(\\\"Video ready hai! Download karo \\u1f389\\\",\\\"ok\\\");document.getElementById(\\\"dlv\\\").disabled=false;document.getElementById(\\\"dla\\\").disabled=false;isGen=false;btn.disabled=false;btn.classList.remove(\\\"loading\\\");btn.childNodes[1].textContent=\\\" Generate Again\\\";await sleep(2000);hideProgress();}\n",
    "async function doDownload(){if(!genImgs.length){setS(\\\"Pehle generate karo!\\\",\\\"er\\\");return;}const cv=document.getElementById(\\\"cv\\\"),ctx=cv.getContext(\\\"2d\\\"),W=cv.width,H=cv.height,fps=parseInt(document.getElementById(\\\"fps\\\").value),dur=parseInt(document.getElementById(\\\"dur\\\").value),kb=document.getElementById(\\\"kb\\\").checked,FPF=fps*dur;const mimes=[\\\"video/webm;codecs=vp9\\\",\\\"video/webm;codecs=vp8\\\",\\\"video/webm\\\"];let mime=\\\"video/webm\\\";for(const m of mimes){try{if(MediaRecorder.isTypeSupported(m)){mime=m;break;}}catch(e){}}let stream;try{stream=cv.captureStream(fps);}catch(e){setS(\\\"captureStream nahi chala - Chrome use karein\\\",\\\"er\\\");return;}const chunks=[],rec=new MediaRecorder(stream,{mimeType:mime,videoBitsPerSecond:5000000});rec.ondataavailable=e=>{if(e.data&&e.data.size>0)chunks.push(e.data);};rec.onstop=()=>{const blob=new Blob(chunks,{type:mime}),url=URL.createObjectURL(blob),a=document.createElement(\\\"a\\\");a.href=url;a.download=\\\"ShivAI_\\\"+Date.now()+\\\".webm\\\";document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);setS(\\\"Video download ho gayi! \\u2705\\\",\\\"ok\\\");};rec.start(100);setS(\\\"Recording...\\\",\\\"go\\\");setProgress(0,\\\"Recording\\\");let total=genScenes.length*FPF,done=0;for(let i=0;i<genScenes.length;i++){for(let f=0;f<FPF;f++){drawFrame(ctx,genImgs[i]||null,W,H,f,FPF,genScenes[i],kb);await sleep(Math.round(1000/fps));done++;setProgress(Math.round(done/total*100));}}rec.stop();hideProgress();}\n",
