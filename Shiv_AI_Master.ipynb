# --- 5. NUMPY FIX (Critical) ðŸ› ï¸ ---
print("ðŸ©¹ Fixing NumPy Version...")
# Numba needs numpy < 2.2
!pip install "numpy<2.2"

# --- 6. Link Libraries (Path Fix) ---
print("ðŸ”— Linking CUDA libraries for AI...")
package_paths = site.getsitepackages()
nv_paths = []
for p in package_paths:
    nvidia_dir = os.path.join(p, "nvidia")
    if os.path.exists(nvidia_dir):
        for root, dirs, files in os.walk(nvidia_dir):
            if 'lib' in dirs:
                nv_paths.append(os.path.join(root, 'lib'))
    trt_dir = os.path.join(p, "tensorrt_libs")
    if os.path.exists(trt_dir):
        nv_paths.append(trt_dir)

env_path = os.environ.get("LD_LIBRARY_PATH", "")
extra_paths = ":".join(nv_paths)
os.environ["LD_LIBRARY_PATH"] = f"{env_path}:{extra_paths}" if env_path else extra_paths

# --- 7. Launch ---
print("ðŸš€ Launching Wan2GP (Wait for link)...")
!export LD_LIBRARY_PATH=$LD_LIBRARY_PATH && python wgp.py --share
